# Copy to .env and fill in. docker-compose reads this automatically.

# Aviary API authorization key (used server-side for all requests).
AVIARY_API_KEY=

# Shared password that gates the admin UI.
APP_PASSWORD=change-me

# Secret used to sign session cookies. Generate one, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Optional: where job working dirs / output zips are written (default ./data).
# DATA_DIR=/data

# Optional escape hatch: set to 1 to disable the password gate entirely
# (only if the app is on a trusted private network).
# ALLOW_NO_AUTH=0
